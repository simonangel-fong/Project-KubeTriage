## 1.1 Infrastructure setup

```sh
# deploy nginx
kubectl create deployment nginx --image=nginx:latest --replicas=2
kubectl expose deployment nginx --port=80

kubectl get deploy
# NAME    READY   UP-TO-DATE   AVAILABLE   AGE
# nginx   2/2     2            2           16s


# install prom + grafana
helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
helm repo update

cd monitoring/helm
helm upgrade --install kube-prometheus-stack prometheus-community/kube-prometheus-stack --version "82.15.1" --namespace monitoring --create-namespace --values=values.yaml

# access grafana
kubectl port-forward svc/kube-prometheus-stack-grafana -n monitoring 3000:80

# confirm Prometheus is scraping your nginx
kubectl port-forward svc/kube-prometheus-stack-prometheus -n monitoring 9090:9090
# localhost:9090/targets

# add service monitor
kubectl apply -f monitoring/manifests/nginx-servicemonitor.yaml
# servicemonitor.monitoring.coreos.com/nginx-monitor created

kubectl get servicemonitor.monitoring.coreos.com/nginx-monitor -n monitoring
# NAME            AGE
# nginx-monitor   83s
```

